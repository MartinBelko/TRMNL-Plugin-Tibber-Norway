{% comment %} ---- Pre-compute all data in Liquid ---- {% endcomment %}
{% assign max_price = -1 %}
{% assign min_price = 999999 %}
{% assign max_hour = 0 %}
{% assign min_hour = 0 %}

{% for item in energy.todayHours %}
  {% assign ore = item.priceIncludingVat | times: 100.0 %}
  {% if ore > max_price %}
    {% assign max_price = ore %}
    {% assign max_hour = item.hour %}
  {% endif %}
  {% if ore < min_price %}
    {% assign min_price = ore %}
    {% assign min_hour = item.hour %}
  {% endif %}
{% endfor %}

{% assign max_display = max_price | round: 1 %}
{% assign min_display = min_price | round: 1 %}

<script src="https://trmnl.com/js/highcharts/12.3.0/highcharts.js"></script>

<style>
  #chart-container {
    width: 100%;
    height: 100%;
  }
</style>

<div class="layout layout--col gap--small">

  <div class="grid grid--cols-2">
    <div class="item">
      <div class="meta">
        <span class="index">▲</span>
      </div>
      <div class="content">
        <span class="value value--small" data-value-fit="true">{{ max_display }} Øre</span>
        <span class="label label--small">@ {{ max_hour }}:00</span>
      </div>
    </div>
    <div class="item">
      <div class="meta">
        <span class="index">▼</span>
      </div>
      <div class="content">
        <span class="value value--small" data-value-fit="true">{{ min_display }} Øre</span>
        <span class="label label--small">@ {{ min_hour }}:00</span>
      </div>
    </div>
  </div>

  <div class="divider"></div>

  <div id="chart-container" style="flex:1; min-height:0;"></div>

</div>

<div class="title_bar">
  <img style="filter:invert(1)" class="image" src="https://framerusercontent.com/images/DNNK7k8uF1jZfKCEo6XoZd3Yc.svg">
  <span class="title">Tibber Norway</span>
  <span class="instance">Price Today (øre/kWh)</span>
</div>

<script>
  var data = [
    {% for item in energy.todayHours %}
      {% assign ore = item.priceIncludingVat | times: 100.0 | round: 2 %}
      {
        name: "{{ item.hour }}",
        y: {{ ore }},
        {% if item.hour == max_hour %}
          color: "#999999"
        {% elsif item.hour == min_hour %}
          color: "#999999"
        {% else %}
          color: "#ffffff"
        {% endif %}
      }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ];

  Highcharts.chart("chart-container", {
    chart: {
      type: "column",
      backgroundColor: "transparent",
      style: { fontFamily: "NicoPups" }
    },
    title: { text: null },
    credits: { enabled: false },
    legend: { enabled: false },
    xAxis: {
      type: "category",
      title: { text: "Time (Hour)", style: { color: "#000", fontSize: "24px" } },
      labels: { style: { color: "#000", fontSize: "16px" } },
      lineColor: "#000",
      gridLineDashStyle: "dot",
      gridLineWidth: 1,
      gridLineColor: "#000"
    },
    yAxis: {
      title: { text: "Price (Øre)", style: { color: "#000", fontSize: "24px" } },
      labels: { style: { color: "#000", fontSize: "16px" } },
      gridLineColor: "#000",
      gridLineWidth: 1,
      gridLineDashStyle: "shortdot"
    },
    plotOptions: {
      column: {
        animation: false,
        borderColor: "#000000",
        borderWidth: 1.5,
        pointPadding: 0.02,
        groupPadding: 0.02
      }
    },
    tooltip: {
      formatter: function() {
        return "<b>Hour " + this.point.name + "</b><br/>" + this.y.toFixed(2) + " Øre";
      }
    },
    series: [{
      name: "Price",
      colorByPoint: true,
      data: data
    }]
  });
</script>
